{
  "name": "pr-reviews-analysis",
  "version": "1.0.0",
  "description": "Analyze PR review activity across your team using GitHub data",
  "type": "module",
  "scripts": {
    "dev:server": "bun --watch server/server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "start:server": "bun server/server.ts",
    "start:client": "vite",
    "start": "concurrently \"bun run start:server\" \"bun run start:client\"",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "typecheck:client": "tsc --noEmit -p client/tsconfig.json",
    "typecheck": "bun run typecheck:server && bun run typecheck:client",
    "lint:server": "oxlint --tsconfig server/tsconfig.json server",
    "lint:client": "oxlint --tsconfig client/tsconfig.json client/src",
    "lint": "bun run lint:server && bun run lint:client",
    "format:server": "oxfmt server",
    "format:client": "oxfmt client",
    "format": "oxfmt",
    "format:check:server": "oxfmt --check server",
    "format:check:client": "oxfmt --check client",
    "format:check": "oxfmt --check",
    "check:server": "bun run typecheck:server && bun run lint:server && bun run format:check:server",
    "check:client": "bun run typecheck:client && bun run lint:client && bun run format:check:client",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "clean": "rm -rf node_modules bun.lock dist .vite && echo 'Cleaned. Run bun install to reinstall.'"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "chart.js": "^4.5.1",
    "consola": "^3.4.2",
    "hono": "^4.12.15",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  },
  "packageManager": "bun@1.3.0"
}
