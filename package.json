{
  "name": "pr-reviews-analysis",
  "version": "1.0.0",
  "description": "Analyze PR review activity across your team using GitHub data",
  "type": "module",
  "scripts": {
    "dev:server": "node --watch-path=server --watch-path=shared server/server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "start:server": "node server/server.ts",
    "start:client": "vite",
    "start": "concurrently \"pnpm run start:server\" \"pnpm run start:client\"",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "typecheck:client": "tsc --noEmit -p client/tsconfig.json",
    "typecheck": "pnpm run typecheck:server && pnpm run typecheck:client",
    "lint:server": "oxlint --tsconfig server/tsconfig.json server",
    "lint:client": "oxlint --tsconfig client/tsconfig.json client/src",
    "lint": "pnpm run lint:server && pnpm run lint:client",
    "format:server": "oxfmt server",
    "format:client": "oxfmt client",
    "format": "oxfmt",
    "format:check:server": "oxfmt --check server",
    "format:check:client": "oxfmt --check client",
    "format:check": "oxfmt --check",
    "check:server": "pnpm run typecheck:server && pnpm run lint:server && pnpm run format:check:server",
    "check:client": "pnpm run typecheck:client && pnpm run lint:client && pnpm run format:check:client",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "clean": "rm -rf node_modules .pnpm-store pnpm-lock.yaml dist .vite && echo 'Cleaned. Run pnpm install to reinstall.'"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@hono/zod-validator": "^0.7.6",
    "chart.js": "^4.4.8",
    "consola": "^3.4.2",
    "hono": "^4.12.5",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tailwindcss": "^4.1.1",
    "typescript": "^5.9.3",
    "vite": "^6.2.2"
  }
}
