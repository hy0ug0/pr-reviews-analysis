{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import", "node"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "builtin": true,
    "node": true
  },
  "ignorePatterns": ["dist", "node_modules"],
  "options": {
    "typeAware": true
  },
  "rules": {
    "unicorn/no-array-sort": "off"
  }
}
