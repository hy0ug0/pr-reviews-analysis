# Server port (default: 3000)
PORT=3000

# Default repositories shown in the form on startup.
# Format: owner/repo — comma-separated for multiple repos.
DEFAULT_REPOS=torvalds/linux,microsoft/vscode

# Default label filter pre-filled in the form (leave empty to disable).
DEFAULT_LABEL=bug

# Default team members pre-filled in the form.
# Format: comma-separated GitHub handles.
DEFAULT_TEAM=torvalds,DHowett,joaomoreno,eamodio

# Local cache time-to-live in hours for /api/analyze results.
CACHE_TTL_HOURS=6

# Optional cache directory (relative to project root or absolute path).
CACHE_DIR=.cache/pr-reviews-analysis
